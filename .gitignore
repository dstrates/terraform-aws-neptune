# Local .terraform directories
**/.terraform/*

# Terraform lockfile
.terraform.lock.hcl

# .tfstate files
*.tfstate
*.tfstate.*

# Crash log files
crash.log

# Exclude all .tfvars files, which are likely to contain sensitive data, such as
# password, private keys, and other secrets. These should not be part of version
# control as they are data points which are potentially sensitive and subject
# to change depending on the environment.
*.tfvars

# Ignore override files as they are usually used to override resources locally and so
# are not checked in
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Ignore CLI configuration files
.terraformrc
terraform.rc

# Lambda directories
builds/

# Binaries
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# Go build artifacts
bin/
build/
dist/

# Go workspace files
go.work
go.work.sum

# Coverage reports
coverage.out
*.coverprofile
cover.out

# Test binary
*.test

# Go module vendor directory (optional)
vendor/

# Dependency tooling
Godeps/
.glide/
vendor/

# Go tools
*.pprof
*.trace

# Temporary files
tmp/
*.tmp
*.temp

# IDEs / editors
.idea/
.vscode/
*.swp
*.swo
*~

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Environment files
.env
.env.*

# Generated docs
docs/

# Local tooling
.air.toml
.reflex.conf
